using Microsoft.EntityFrameworkCore;
using ISP_Portal.API.Data;
using ISP_Portal.API.Models;
using ISP_Portal.API.Models.Dtos;

namespace ISP_Portal.API.Services;

// owns the "submit a ticket" workflow - asks TicketRouter where it should go,
// then saves it. doesn't know or care how the routing decision gets made.
public class TicketManager : ITicketManager
{
    private readonly AppDbContext _db;
    private readonly ITicketRouter _router;

    public TicketManager(AppDbContext db, ITicketRouter router)
    {
        _db = db;
        _router = router;
    }

    public async Task<SupportTicket> SubmitTicketAsync(int userId, CreateTicketDto dto)
    {
        var routing = _router.Route(dto.Subject, dto.Description);

        var department = await _db.Departments
            .FirstOrDefaultAsync(d => d.DepartmentName == routing.DepartmentName);

        var ticket = new SupportTicket
        {
            UserId = userId,
            SubscriptionId = dto.SubscriptionId,
            DepartmentId = department?.DepartmentId,
            Subject = dto.Subject,
            Description = dto.Description,
            Priority = routing.Priority,
            Status = TicketStatus.Open
        };

        _db.SupportTickets.Add(ticket);
        await _db.SaveChangesAsync();

        return ticket;
    }
}
