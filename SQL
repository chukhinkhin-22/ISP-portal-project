-- ISP customer portal db
-- started this after sketching the ERD on paper first, tried to keep it to 3NF

CREATE DATABASE IF NOT EXISTS isp_portal CHARACTER SET utf8mb4;
USE isp_portal;

-- customers + staff in one table, role decides what they can do
CREATE TABLE Users (
    UserID INT AUTO_INCREMENT PRIMARY KEY,
    FullName VARCHAR(100) NOT NULL,
    Email VARCHAR(150) NOT NULL UNIQUE,
    PasswordHash VARCHAR(255) NOT NULL,
    Role ENUM('Customer','Staff','Admin') DEFAULT 'Customer',
    Phone VARCHAR(20),
    Address VARCHAR(255),
    CreatedAt TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- internet plans, kept separate so price/speed isn't duplicated on every subscription row
CREATE TABLE Plans (
    PlanID INT AUTO_INCREMENT PRIMARY KEY,
    PlanName VARCHAR(100) NOT NULL,
    SpeedMbps INT NOT NULL,
    MonthlyPrice DECIMAL(10,2) NOT NULL,
    Description VARCHAR(255)
);

CREATE TABLE Network_Nodes (
    NodeID INT AUTO_INCREMENT PRIMARY KEY,
    NodeName VARCHAR(100) NOT NULL,
    Region VARCHAR(100) NOT NULL,
    Capacity INT NOT NULL,
    Status ENUM('Active','Maintenance','Offline') DEFAULT 'Active'
);

--lookup table for ticket routing 
-- router assigns a DepartmentID instead of
-- writing "billing" as plain text on the ticket itself
CREATE TABLE Departments (
    DepartmentID INT AUTO_INCREMENT PRIMARY KEY,
    DepartmentName VARCHAR(100) NOT NULL UNIQUE,
    Description VARCHAR(255)
);

CREATE TABLE Subscriptions (
    SubscriptionID INT AUTO_INCREMENT PRIMARY KEY,
    UserID INT NOT NULL,
    PlanID INT NOT NULL,
    NodeID INT NOT NULL,
    StartDate DATE NOT NULL,
    Status ENUM('Active','Suspended','Cancelled') DEFAULT 'Active',
    FOREIGN KEY (UserID) REFERENCES Users(UserID),
    FOREIGN KEY (PlanID) REFERENCES Plans(PlanID),
    FOREIGN KEY (NodeID) REFERENCES Network_Nodes(NodeID)
);

-- SubscriptionID can be null -- someone might submit a ticket that isn't tied
-- to a specific subscription (e.g. just asking a general question)
-- DepartmentID starts null until the router runs and assigns one
CREATE TABLE Support_Tickets (
    TicketID INT AUTO_INCREMENT PRIMARY KEY,
    UserID INT NOT NULL,
    SubscriptionID INT NULL,
    DepartmentID INT NULL,
    Subject VARCHAR(150) NOT NULL,
    Description TEXT NOT NULL,
    Priority ENUM('Low','Medium','High') DEFAULT 'Medium',
    Status ENUM('Open','In_Progress','Resolved','Closed') DEFAULT 'Open',
    CreatedAt TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    ResolvedAt TIMESTAMP NULL,
    FOREIGN KEY (UserID) REFERENCES Users(UserID),
    FOREIGN KEY (SubscriptionID) REFERENCES Subscriptions(SubscriptionID) ON DELETE SET NULL,
    FOREIGN KEY (DepartmentID) REFERENCES Departments(DepartmentID) ON DELETE SET NULL
);

-- comment thread on a ticket, gets wiped if the ticket itself is deleted
CREATE TABLE Ticket_Comments (
    CommentID INT AUTO_INCREMENT PRIMARY KEY,
    TicketID INT NOT NULL,
    UserID INT NOT NULL,
    Message TEXT NOT NULL,
    CreatedAt TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (TicketID) REFERENCES Support_Tickets(TicketID) ON DELETE CASCADE,
    FOREIGN KEY (UserID) REFERENCES Users(UserID)
);

-- indexes for the queries i'll actually be running a lot (staff queue, customer history, login)
CREATE INDEX idx_ticket_status ON Support_Tickets(Status);
CREATE INDEX idx_ticket_department ON Support_Tickets(DepartmentID);
CREATE INDEX idx_ticket_user ON Support_Tickets(UserID);
CREATE INDEX idx_subscription_user ON Subscriptions(UserID);

